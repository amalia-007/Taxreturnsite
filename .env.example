# ─────────────────────────────────────────────────────────────────────────────
# Supabase — get from: supabase.com → your project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — get from: dashboard.stripe.com → Developers → API keys
# Switch to live keys (sk_live_...) before going to production
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude AI — for payslip OCR and deduction suggestions)
# get from: console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# Resend (transactional email — welcome email + payment receipt)
# get from: resend.com → API Keys
# Verify your sending domain (e.g. getmytax.com.au) in Resend before sending
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────────────────────────────────────
# Site URL (used in Stripe redirects and email links)
# ─────────────────────────────────────────────────────────────────────────────
SITE_URL=https://amalia-007.github.io/Taxreturnsite
